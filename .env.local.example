# Copiar a .env.local y completar valores

# Solo desarrollo local: evita redirección a /login en rutas protegidas (middleware).
# NO activar en Preview/Production. Las APIs que requieren sesión (ej. POST /api/pedidos)
# siguen devolviendo 401 sin cookie de Supabase — útil para ver catálogo/UI sin OTP.
# AUTH_DEV_BYPASS=true

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secreto del servidor (bypass RLS). NO uses la clave publishable (sb_publishable_…) ni la anon.
SUPABASE_SERVICE_ROLE_KEY=

# Configuración del Motor IA (LLM)
# LLM_PROVIDER opciones: anthropic, google, openai, deepseek, openai-compatible
LLM_PROVIDER=anthropic 
# Modelo Anthropic (@ai-sdk/anthropic). El 3.5-sonnet 20241022 fue retirado; usar Sonnet 4 u otro vigente.
LLM_MODEL=claude-sonnet-4-20250514
# Opcional: solo para POST /api/suelo/ocr (Vision). Por defecto mismo tipo Sonnet 4.
# ANTHROPIC_OCR_MODEL=claude-sonnet-4-20250514
# Usa LLM_API_KEY para no atarte a un nombre en especifico
LLM_API_KEY=
# Si usas "openai-compatible" (ej. Groq, TogetherAI, xAI, Ollama), define la URL base:
# LLM_BASE_URL=https://api.groq.com/openai/v1

WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Secreto para GET /api/health/ready en producción (Bearer). Mismo valor en Vercel y en GitHub Actions (HEALTH_CHECK_SECRET).
# HEALTH_CHECK_SECRET=

# Verificación local (Supabase + WhatsApp GET): npm run verify:local
# Para probar variables copiadas desde Vercel Production sin commitearlas:
#   creá .env.supabase.prod (ya está en .gitignore) y: npm run verify:prod
