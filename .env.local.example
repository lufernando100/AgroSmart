# Copiar a .env.local y completar valores

# Solo desarrollo local: evita redirección a /login en rutas protegidas (middleware).
# NO activar en Preview/Production. Las APIs que requieren sesión (ej. POST /api/pedidos)
# siguen devolviendo 401 sin cookie de Supabase — útil para ver catálogo/UI sin OTP.
# AUTH_DEV_BYPASS=true

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secreto del servidor (bypass RLS). NO uses la clave publishable (sb_publishable_…) ni la anon.
SUPABASE_SERVICE_ROLE_KEY=

# Configuración del Motor IA (LLM)
LLM_PROVIDER=anthropic # Options: anthropic, google, openai
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Secreto para GET /api/health/ready en producción (Bearer). Mismo valor en Vercel y en GitHub Actions (HEALTH_CHECK_SECRET).
# HEALTH_CHECK_SECRET=

# Verificación local (Supabase + WhatsApp GET): npm run verify:local
# Para probar variables copiadas desde Vercel Production sin commitearlas:
#   creá .env.supabase.prod (ya está en .gitignore) y: npm run verify:prod
